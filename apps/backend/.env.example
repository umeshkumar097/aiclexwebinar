# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zonvo_dev
DB_USER=zonvo
DB_PASSWORD=zonvo_dev_password_local
DB_SSL=false
# DB_SSL_CA=/path/to/ca.pem  # For production managed DB

# ─── Redis (App — sessions, cache, pub/sub) ───────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Redis (Queue — BullMQ) ───────────────────────────────────────────────────
QUEUE_REDIS_HOST=localhost
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=
QUEUE_REDIS_DB=1

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate keys:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   cat private.pem | base64 | tr -d '\n'
JWT_PRIVATE_KEY=REPLACE_WITH_BASE64_ENCODED_RS256_PRIVATE_KEY
JWT_PUBLIC_KEY=REPLACE_WITH_BASE64_ENCODED_RS256_PUBLIC_KEY
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY_DAYS=30

# ─── Email — Resend ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_REPLACE_ME
RESEND_FROM_EMAIL=notifications@mail.zonvo.io
RESEND_FROM_NAME=Zonvo

# ─── WhatsApp — Meta Cloud API ────────────────────────────────────────────────
META_WA_ACCESS_TOKEN=REPLACE_ME
META_WA_PHONE_NUMBER_ID=REPLACE_ME
META_WA_API_VERSION=v20.0

# ─── Storage ──────────────────────────────────────────────────────────────────
# Options: azure | minio
STORAGE_PROVIDER=minio

# Azure Blob Storage (production)
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_ENDPOINT=

# MinIO (local dev)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=zonvo_minio
MINIO_SECRET_KEY=zonvo_minio_secret
MINIO_USE_SSL=false

# ─── LiveKit ─────────────────────────────────────────────────────────────────
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# ─── TURN / coturn ───────────────────────────────────────────────────────────
TURN_URL=turn:localhost:3478
TURN_TLS_URL=turns:localhost:5349
TURN_USERNAME=zonvo
TURN_CREDENTIAL=zonvo_turn_dev_secret

# ─── Stripe (Phase 7) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Swagger ─────────────────────────────────────────────────────────────────
SWAGGER_ENABLED=true

# ─── Rate Limiting ────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=300
