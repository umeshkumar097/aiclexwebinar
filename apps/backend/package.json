{
  "name": "@zonvo/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Zonvo NestJS Backend API",
  "scripts": {
    "build": "nest build",
    "start": "node -r tsconfig-paths/register dist/main.js",
    "start:dev": "ts-node -r tsconfig-paths/register --project tsconfig.json src/main.ts",
    "start:worker": "nest start --watch --entryFile worker",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "test": "jest --config jest.config.ts",
    "test:watch": "jest --config jest.config.ts --watch",
    "test:cov": "jest --config jest.config.ts --coverage",
    "test:integration": "jest --config jest.integration.config.ts --runInBand",
    "test:e2e": "jest --config jest.e2e.config.ts --runInBand",
    "db:migrate": "typeorm migration:run -d src/database/data-source.ts",
    "db:migrate:revert": "typeorm migration:revert -d src/database/data-source.ts",
    "db:migration:generate": "typeorm migration:generate -d src/database/data-source.ts",
    "db:seed": "ts-node src/database/seeds/index.ts",
    "db:schema:drop": "typeorm schema:drop -d src/database/data-source.ts",
    "start:watch": "nodemon --watch src --ext ts --exec \"ts-node -r tsconfig-paths/register --project tsconfig.json src/main.ts\"",
    "start:nest": "nest start --watch"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1078.0",
    "@aws-sdk/s3-request-presigner": "^3.1078.0",
    "@azure/storage-blob": "^12.25.0",
    "@fastify/compress": "^8.3.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/static": "^7.0.4",
    "@nestjs/bullmq": "^10.2.1",
    "@nestjs/common": "^10.4.1",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-fastify": "^10.4.1",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/typeorm": "^10.0.2",
    "@react-email/components": "^0.0.22",
    "@react-email/render": "^0.0.17",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "crypto": "^1.0.1",
    "dayjs": "^1.11.13",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "livekit-server-sdk": "^2.6.1",
    "minio": "^8.0.1",
    "nodemailer": "^6.10.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reflect-metadata": "^0.2.2",
    "resend": "^4.0.0",
    "rxjs": "^7.8.1",
    "stripe": "^22.3.0",
    "typeorm": "^0.3.20",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.5.0",
    "@types/nodemailer": "^6.4.24",
    "@types/passport-jwt": "^4.0.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.2.0",
    "@typescript-eslint/parser": "^8.2.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.3",
    "webpack": "^5.108.4"
  }
}
