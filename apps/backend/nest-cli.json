{
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "entryFile": "main",
  "projects": {
    "backend": {
      "type": "application",
      "root": "",
      "entryFile": "main",
      "sourceRoot": "src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.json"
      }
    },
    "worker": {
      "type": "application",
      "root": "",
      "entryFile": "worker",
      "sourceRoot": "src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.json"
      }
    }
  },
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": false,
    "plugins": ["@nestjs/swagger/plugin"]
  }
}
